# ===========================
# GEMINI FOLDERS - GITIGNORE
# ===========================

# --- Security & Privacy (CRITICAL) ---
# Ignore all JSON files to prevent accidental commit of personal backups
*.json

# Exception: manifest.json MUST be committed as it is part of the source code
!manifest.json

# Exception: package.json (if you add npm later, un-comment this line)
# !package.json

# --- Chrome Extension Artifacts ---
# Packed extension files generated by Chrome
*.crx
# Private keys generated by Chrome (NEVER COMMIT THIS)
*.pem

# --- OS System Files ---
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
