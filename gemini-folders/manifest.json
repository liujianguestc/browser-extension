{
  "manifest_version": 3,
  "name": "Gemini Folders",
  "version": "1.0",
  "description": "Organize Gemini chats into custom folders with backup functionality.",
  "permissions": [
    "storage" 
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}