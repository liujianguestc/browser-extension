{
  "manifest_version": 3,
  "name": "Gemini导航助手",
  "version": "5.0",
  "description": "Gemini对话导航与Markdown导出工具",
  "permissions": ["activeTab", "downloads"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "all_frames": true,
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
